// Weighted straight skeleton bindings
sub.def("create_interior_weighted_straight_skeleton", [](
    const Polygon_2 &polygon, const std::vector<double>& weights) -> Skeleton_2_Ref {
    std::vector<Kernel::FT> cgal_weights;
    cgal_weights.reserve(weights.size());
    for (double w : weights) {
        cgal_weights.push_back(Kernel::FT(w));
    }
    return to_std(CGAL::create_interior_weighted_straight_skeleton_2(
        polygon, cgal_weights, Kernel()));
});

