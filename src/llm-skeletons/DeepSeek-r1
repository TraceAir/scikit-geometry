// Weighted offset polygon bindings
sub.def("create_interior_weighted_offset_polygons", [](
    const Polygon_2 &polygon, const std::vector<double>& weights, double offset) -> py::list {
    std::vector<Kernel::FT> cgal_weights;
    cgal_weights.reserve(weights.size());
    for (double w : weights) {
        cgal_weights.push_back(Kernel::FT(w));
    }

    py::list r;
    auto result = CGAL::create_interior_weighted_skeleton_and_offset_polygons_2(
        Kernel::FT(offset), polygon, cgal_weights, Kernel());
    for (const auto &polygon : result) {
        r.append(py::cast(new Polygon_2(*polygon), pybind11::return_value_policy::automatic));
    }
    return r;
});

